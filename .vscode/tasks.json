{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: dev",
      "type": "shell",
      "command": "npm run dev",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      }
    },
    {
      "label": "cargo: build",
      "type": "shell",
      "command": "cargo build",
      "options": { "cwd": "${workspaceFolder}/src-tauri" },
      "group": "build",
      "problemMatcher": "$rustc"
    },
    {
      "label": "cargo: check",
      "type": "shell",
      "command": "cargo check",
      "options": { "cwd": "${workspaceFolder}/src-tauri" },
      "group": "build",
      "problemMatcher": "$rustc"
    },
    {
      "label": "tauri: dev",
      "type": "shell",
      "command": "npm run tauri:dev",
      "group": { "kind": "build", "isDefault": true },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Running",
          "endsPattern": "Finished"
        }
      }
    },
    {
      "label": "tauri: build",
      "type": "shell",
      "command": "npm run tauri:build",
      "group": "build",
      "problemMatcher": "$rustc"
    },
    {
      "label": "cargo: clippy",
      "type": "shell",
      "command": "cargo clippy --all-targets --all-features -- -D warnings",
      "options": { "cwd": "${workspaceFolder}/src-tauri" },
      "group": "test",
      "problemMatcher": "$rustc"
    },
    {
      "label": "cargo: test",
      "type": "shell",
      "command": "cargo test",
      "options": { "cwd": "${workspaceFolder}/src-tauri" },
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": "$rustc"
    },
    {
      "label": "svelte: check",
      "type": "shell",
      "command": "npm run check",
      "group": "test",
      "problemMatcher": []
    }
  ]
}
